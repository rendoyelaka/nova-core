<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_drawer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- MaterialToolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_drawer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="32dp"
        android:background="@color/colorBackground"
        app:title="@string/all_apps"
        app:titleTextColor="@color/colorTextPrimary"
        app:navigationIcon="@drawable/ic_arrow_down"
        app:navigationIconTint="@color/colorTextPrimary" />

    <!-- Search TextInputLayout -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_search_drawer"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginTop="8dp"
        android:hint="@string/search_apps"
        app:boxStrokeColor="@color/colorAccent"
        app:boxBackgroundColor="@color/colorInputBackground"
        app:hintTextColor="@color/colorTextHint"
        app:startIconDrawable="@drawable/ic_search"
        app:startIconTint="@color/colorTextHint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_search_drawer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextPrimary"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_drawer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all_drawer"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_all"
                android:textColor="@color/colorTextPrimary"
                android:checked="true"
                app:chipBackgroundColor="@color/colorChipBackground"
                app:chipStrokeColor="@color/colorAccent"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_user_drawer"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_user"
                android:textColor="@color/colorTextPrimary"
                app:chipBackgroundColor="@color/colorChipBackground"
                app:chipStrokeColor="@color/colorAccent"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_system_drawer"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_system"
                android:textColor="@color/colorTextPrimary"
                app:chipBackgroundColor="@color/colorChipBackground"
                app:chipStrokeColor="@color/colorAccent"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_recent_drawer"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_recent"
                android:textColor="@color/colorTextPrimary"
                app:chipBackgroundColor="@color/colorChipBackground"
                app:chipStrokeColor="@color/colorAccent"
                app:chipStrokeWidth="1dp" />

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- No apps -->
    <TextView
        android:id="@+id/tv_no_apps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/no_apps_found"
        android:textColor="@color/colorTextSecondary"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- App Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_apps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="24dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:clipToPadding="false"
        android:overScrollMode="never" />

</LinearLayout>
