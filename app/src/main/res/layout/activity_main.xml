<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main Content -->
    <RelativeLayout
        android:id="@+id/root_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorBackground">

        <!-- Clock & Date -->
        <LinearLayout
            android:id="@+id/layout_clock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingLeft="24dp"
            android:paddingRight="24dp">

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:00"
                android:textColor="@color/colorTextPrimary"
                android:textSize="52sp"
                android:fontFamily="sans-serif-light" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Monday, Jan 01"
                android:textColor="@color/colorTextSecondary"
                android:textSize="14sp"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Search Bar (hidden by default) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_search_bar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/layout_clock"
            android:layout_marginTop="16dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:visibility="gone"
            app:boxStrokeColor="@color/colorAccent"
            app:boxBackgroundColor="@color/colorInputBackground"
            app:hintTextColor="@color/colorTextHint"
            android:hint="@string/search_apps">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/colorTextPrimary"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Filter Chips -->
        <HorizontalScrollView
            android:id="@+id/chip_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/layout_search_bar"
            android:layout_marginTop="8dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:scrollbars="none"
            android:visibility="gone">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_all"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_all"
                    android:textColor="@color/colorTextPrimary"
                    android:checked="true"
                    app:chipBackgroundColor="@color/colorChipBackground"
                    app:chipStrokeColor="@color/colorAccent"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_user"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_user"
                    android:textColor="@color/colorTextPrimary"
                    app:chipBackgroundColor="@color/colorChipBackground"
                    app:chipStrokeColor="@color/colorAccent"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_system"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_system"
                    android:textColor="@color/colorTextPrimary"
                    app:chipBackgroundColor="@color/colorChipBackground"
                    app:chipStrokeColor="@color/colorAccent"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_recent"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_recent"
                    android:textColor="@color/colorTextPrimary"
                    app:chipBackgroundColor="@color/colorChipBackground"
                    app:chipStrokeColor="@color/colorAccent"
                    app:chipStrokeWidth="1dp" />

            </com.google.android.material.chip.ChipGroup>

        </HorizontalScrollView>

        <!-- Dock (Bottom) -->
        <LinearLayout
            android:id="@+id/layout_dock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="32dp"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/swipe_up_hint"
                android:textColor="@color/colorTextHint"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dock"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:orientation="horizontal"
                android:gravity="center">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_favorite_apps"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:overScrollMode="never"
                    android:clipToPadding="false" />

                <ImageButton
                    android:id="@+id/btn_all_apps"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_icon_button"
                    android:src="@drawable/ic_apps"
                    android:tint="@color/colorIconTint"
                    android:contentDescription="@string/all_apps"
                    android:scaleType="centerInside"
                    android:padding="12dp" />

            </LinearLayout>

            <!-- Bottom Controls Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <!-- Menu Button -->
                <ImageButton
                    android:id="@+id/btn_menu"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@null"
                    android:src="@drawable/ic_menu"
                    android:tint="@color/colorTextSecondary"
                    android:contentDescription="@string/open_nav"
                    android:scaleType="centerInside" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- Settings Button -->
                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@null"
                    android:src="@drawable/ic_settings"
                    android:tint="@color/colorTextSecondary"
                    android:contentDescription="@string/settings"
                    android:scaleType="centerInside" />

            </LinearLayout>

        </LinearLayout>

        <!-- FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_add"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_marginBottom="140dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_add"
            android:contentDescription="@string/add_widget"
            app:backgroundTint="@color/colorFabBackground"
            app:tint="@color/colorOnPrimary"
            app:elevation="6dp"
            android:visibility="gone" />

    </RelativeLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@drawable/bg_navigation_drawer"
        app:itemTextColor="@color/colorTextPrimary"
        app:itemIconTint="@color/colorIconTint"
        app:menu="@menu/nav_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
