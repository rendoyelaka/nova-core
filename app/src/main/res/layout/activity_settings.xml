<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="48dp"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <ImageButton
                android:id="@+id/btn_back_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@null"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/colorTextPrimary"
                android:contentDescription="Back"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/launcher_settings"
                android:textColor="@color/colorTextPrimary"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <!-- Section: Appearance -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appearance"
            android:textColor="@color/colorAccent"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="24dp"
            android:paddingBottom="8dp" />

        <!-- Show Clock -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:background="@drawable/bg_settings_item">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/show_clock"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Display time on home screen"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp" />

            </LinearLayout>

            <Switch
                android:id="@+id/switch_show_clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Dark Mode -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:background="@drawable/bg_settings_item">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dark_mode"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Use dark background theme"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp" />

            </LinearLayout>

            <Switch
                android:id="@+id/switch_dark_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="24dp" />

        <!-- Section: Customization -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Customization"
            android:textColor="@color/colorAccent"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="24dp"
            android:paddingBottom="8dp" />

        <Button
            android:id="@+id/btn_change_wallpaper"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="12dp"
            android:text="@string/change_wallpaper"
            android:backgroundTint="@color/colorCard"
            android:textColor="@color/colorTextPrimary"
            style="@style/Widget.MaterialComponents.Button" />

        <Button
            android:id="@+id/btn_clear_favorites"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="12dp"
            android:text="@string/clear_favorites"
            android:backgroundTint="@color/colorCard"
            android:textColor="@color/colorTextPrimary"
            style="@style/Widget.MaterialComponents.Button" />

        <Button
            android:id="@+id/btn_set_default_launcher"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="24dp"
            android:text="@string/set_default_launcher"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/colorOnPrimary"
            style="@style/Widget.MaterialComponents.Button" />

        <!-- Version -->
        <TextView
            android:id="@+id/tv_version"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Version 1.0"
            android:textColor="@color/colorTextHint"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingTop="8dp" />

    </LinearLayout>

</ScrollView>
